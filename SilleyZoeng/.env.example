# Required: Anthropic API key for Claude evaluations
ANTHROPIC_API_KEY=sk-ant-api03-...

# Path to local Claude Code skills directory
SKILLS_DIR=~/.claude/skills

# Path to how-to-work-together harness framework
HARNESS_DIR=/Users/fanjingwen/Projects/teamo/teamo-router/how-to-work-together

# Ollama configuration (for local judge model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_JUDGE_MODEL=llama3.1:8b

# Claude model for evaluation (default: claude-sonnet-4-20250514)
EVAL_MODEL=claude-sonnet-4-20250514
