{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CrossServiceIssuePacket",
  "type": "object",
  "required": [
    "issueId",
    "fromService",
    "toService",
    "severity",
    "traceId",
    "summary",
    "expected",
    "actual",
    "reproCommand",
    "contractVersion",
    "createdAt"
  ],
  "properties": {
    "issueId": { "type": "string" },
    "fromService": { "type": "string" },
    "toService": { "type": "string" },
    "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
    "traceId": { "type": "string" },
    "summary": { "type": "string" },
    "expected": { "type": "string" },
    "actual": { "type": "string" },
    "requestSnapshot": { "type": "object" },
    "responseSnapshot": { "type": "object" },
    "errorLog": { "type": "string" },
    "reproCommand": { "type": "string" },
    "contractVersion": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
