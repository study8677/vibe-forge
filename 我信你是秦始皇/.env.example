# ============================
# Amadeus API 配置
# 免费注册: https://developers.amadeus.com
# 注册后在 My Self-Service Workspace 获取 API Key
# ============================
AMADEUS_API_KEY=your_api_key_here
AMADEUS_API_SECRET=your_api_secret_here
# test = 测试环境(模拟数据), production = 生产环境(真实价格)
AMADEUS_ENV=test

# ============================
# 邮件 SMTP 配置
# QQ邮箱: smtp.qq.com / 465 / SSL
# 163邮箱: smtp.163.com / 465 / SSL
# Gmail:  smtp.gmail.com / 587 / TLS (设 SMTP_USE_SSL=false)
# ============================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_authorization_code
SMTP_USE_SSL=true

# ============================
# 监控配置
# ============================
# 降价通知收件人
NOTIFY_EMAIL=recipient@example.com
# 降价阈值 (元), 降幅超过此值才发送通知
PRICE_DROP_THRESHOLD=50
# 监控检查间隔 (分钟)
CHECK_INTERVAL=30
